# --- Spotify ---
# Create an app at https://developer.spotify.com/dashboard (a Premium account is required
# to register a dev app as of Feb 2026). Copy the Client ID here.
SPOTIFY_CLIENT_ID=your_spotify_client_id

# The redirect URI must be registered EXACTLY (byte-for-byte) in the Spotify dashboard.
# Spotify rejects plain "localhost" for non-HTTPS redirects — use the loopback IP form.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:4477/callback

# --- OpenAI (GPT-5.5 classification) ---
OPENAI_API_KEY=your_openai_api_key
# Optional model override (defaults to gpt-5.5).
OPENAI_MODEL=gpt-5.5

# --- Local server ---
# Port the local web UI listens on. Must match the port in SPOTIFY_REDIRECT_URI.
PORT=4477
