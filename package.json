{
  "name": "spotify-vibe-sorter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sort your scattered Spotify library into custom vibe playlists and get a shareable music-personality card — all locally.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "start": "tsx src/server/index.ts",
    "vibe": "tsx src/cli.ts both",
    "sort": "tsx src/cli.ts sort",
    "profile": "tsx src/cli.ts profile",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
